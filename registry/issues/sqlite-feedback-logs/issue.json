{
  "$schema": "../../schema/issue.schema.json",
  "id": "sqlite-feedback-logs",
  "title": "Codex writes excessive SQLite feedback logs",
  "status": "active",
  "severity": "high",
  "summary": "Codex can write excessive diagnostic logs into logs_2.sqlite and logs_2.sqlite-wal. The upstream issue appears to come from overly verbose persisted logging. This local fix adds a SQLite trigger that ignores new inserts into the logs table, which prevents further persistent log growth while leaving the diagnostic database in place. The issue can recur if Codex recreates the database or changes its schema before fixing the logging behavior upstream.",
  "sources": {
    "issues": [
      "https://github.com/openai/codex/issues/28224",
      "https://github.com/openai/codex/issues/28997",
      "https://github.com/openai/codex/issues/17320"
    ],
    "fixes": [
      "https://github.com/openai/codex/issues/17320#issuecomment-4514992998"
    ]
  },
  "targets": {
    "cli": {
      "darwin-arm64": {
        "applies": "Yes",
        "script": "scripts/fix.ts"
      },
      "darwin-x64": {
        "applies": "Yes",
        "script": "scripts/fix.ts"
      },
      "linux-arm64": {
        "applies": "Yes",
        "script": "scripts/fix.ts"
      },
      "linux-x64": {
        "applies": "Yes",
        "script": "scripts/fix.ts"
      },
      "win32-arm64": {
        "applies": "Yes",
        "script": "scripts/fix.ts"
      },
      "win32-x64": {
        "applies": "Yes",
        "script": "scripts/fix.ts"
      }
    },
    "desktop": {
      "darwin-arm64": {
        "applies": "Yes",
        "script": "scripts/fix.ts"
      },
      "darwin-x64": {
        "applies": "Yes",
        "script": "scripts/fix.ts"
      },
      "win32-x64": {
        "applies": "Yes",
        "script": "scripts/fix.ts"
      }
    }
  }
}
