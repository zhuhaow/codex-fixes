---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Community-maintained diagnostics and workarounds for Codex issues."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">Codex Fixes</a>
      <nav aria-label="Main navigation">
        <a href="/issues/">Issues</a>
        <a href="/install/">Install</a>
        <a href="https://github.com/" rel="noreferrer">GitHub</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --background: #f7f8f5;
    --surface: #ffffff;
    --surface-muted: #eef1ed;
    --text: #151814;
    --muted: #5d665a;
    --line: #d9ded6;
    --accent: #186b52;
    --accent-strong: #0e4f3d;
    --warning: #a15c16;
    --danger: #9a2d36;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--background);
    color: var(--text);
  }

  body {
    margin: 0;
    min-height: 100vh;
  }

  a {
    color: inherit;
  }

  .site-header {
    align-items: center;
    border-bottom: 1px solid var(--line);
    display: flex;
    gap: 24px;
    justify-content: space-between;
    margin: 0 auto;
    max-width: 1120px;
    padding: 18px 24px;
  }

  .brand {
    color: var(--text);
    font-size: 18px;
    font-weight: 760;
    text-decoration: none;
  }

  nav {
    align-items: center;
    display: flex;
    gap: 18px;
  }

  nav a {
    color: var(--muted);
    font-size: 14px;
    text-decoration: none;
  }

  nav a:hover {
    color: var(--text);
  }

  main {
    margin: 0 auto;
    max-width: 1120px;
    padding: 36px 24px 72px;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    font-size: clamp(38px, 6vw, 72px);
    letter-spacing: 0;
    line-height: 0.96;
    margin-bottom: 22px;
    max-width: 860px;
  }

  h2 {
    font-size: 24px;
    letter-spacing: 0;
    line-height: 1.2;
  }

  p {
    color: var(--muted);
    font-size: 18px;
    line-height: 1.6;
  }

  code,
  pre {
    font-family:
      "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
  }

  .command {
    align-items: center;
    background: #121611;
    border-radius: 8px;
    color: #f4f7f2;
    display: flex;
    font-size: 15px;
    justify-content: space-between;
    overflow-x: auto;
    padding: 16px 18px;
    white-space: nowrap;
  }

  .eyebrow {
    color: var(--accent-strong);
    font-size: 13px;
    font-weight: 780;
    letter-spacing: 0.08em;
    margin-bottom: 18px;
    text-transform: uppercase;
  }

  .section {
    margin-top: 52px;
  }

  .grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 20px;
  }

  .card h3 {
    font-size: 17px;
    letter-spacing: 0;
    margin-bottom: 10px;
  }

  .card p {
    font-size: 15px;
    line-height: 1.5;
    margin-bottom: 0;
  }

  .status-row {
    border: 1px solid var(--line);
    border-radius: 8px;
    display: grid;
    gap: 14px;
    grid-template-columns: 1fr auto auto;
    padding: 16px;
  }

  .status-row + .status-row {
    margin-top: 12px;
  }

  .pill {
    align-self: start;
    background: var(--surface-muted);
    border-radius: 999px;
    color: var(--muted);
    font-size: 12px;
    font-weight: 700;
    padding: 6px 10px;
    white-space: nowrap;
  }

  @media (max-width: 760px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
    }

    nav {
      flex-wrap: wrap;
    }

    .grid,
    .status-row {
      grid-template-columns: 1fr;
    }

    h1 {
      font-size: 42px;
    }
  }
</style>
