---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Issues - Codex Fixes"
  description="Active and historical Codex issues tracked by Codex Fixes."
>
  <div class="min-h-screen bg-white px-6 py-16 text-gray-950 sm:px-8 sm:py-24">
    <div class="mx-auto max-w-4xl">
      <a href="/" class="text-sm font-semibold text-sky-300">Codex Fixes</a>
      <p
        class="mt-12 text-xs/6 font-semibold tracking-[0.18em] text-sky-300 uppercase"
      >
        Registry
      </p>
      <h1
        class="mt-3 text-4xl/tight font-light text-gray-950 sm:text-5xl/tight"
      >
        Tracked Codex Issues
      </h1>
      <p class="mt-5 max-w-2xl text-base/7 text-gray-600">
        This page will list active, historical, and experimental Codex fixes
        once the registry schema is finalized.
      </p>

      <section class="mt-10 space-y-4" aria-label="Placeholder issue list">
        <div class="soft-panel p-5">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <strong class="text-gray-950"
              >Excessive trace database writes</strong
            >
            <div class="flex gap-2">
              <span
                class="rounded-full bg-gray-950/[0.03] px-2.5 py-1 text-xs font-medium text-gray-600 ring-1 ring-gray-950/10"
              >
                planned
              </span>
              <span
                class="rounded-full bg-sky-50 px-2.5 py-1 text-xs font-medium text-sky-700 ring-1 ring-sky-200"
              >
                careful
              </span>
            </div>
          </div>
          <p class="mt-2 text-sm/6 text-gray-600">
            Placeholder for the first real diagnostic and mitigation entry.
          </p>
        </div>
        <div class="soft-panel p-5">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <strong class="text-gray-950">UI CPU usage regression</strong>
            <div class="flex gap-2">
              <span
                class="rounded-full bg-gray-950/[0.03] px-2.5 py-1 text-xs font-medium text-gray-600 ring-1 ring-gray-950/10"
              >
                planned
              </span>
              <span
                class="rounded-full bg-sky-50 px-2.5 py-1 text-xs font-medium text-sky-700 ring-1 ring-sky-200"
              >
                historical
              </span>
            </div>
          </div>
          <p class="mt-2 text-sm/6 text-gray-600">
            Placeholder for a historical or resolved issue entry.
          </p>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>
