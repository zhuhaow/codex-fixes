---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Issues - Codex Fixes"
  description="Active and historical Codex issues tracked by Codex Fixes."
>
  <section>
    <div class="eyebrow">Registry</div>
    <h1>Tracked Codex Issues</h1>
    <p>
      This page will list active, historical, and experimental Codex fixes once
      the registry schema is finalized.
    </p>
  </section>

  <section class="section" aria-label="Placeholder issue list">
    <div class="status-row">
      <div>
        <strong>Excessive trace database writes</strong>
        <p>Placeholder for the first real diagnostic and mitigation entry.</p>
      </div>
      <span class="pill">planned</span>
      <span class="pill">careful</span>
    </div>
    <div class="status-row">
      <div>
        <strong>UI CPU usage regression</strong>
        <p>Placeholder for a historical or resolved issue entry.</p>
      </div>
      <span class="pill">planned</span>
      <span class="pill">historical</span>
    </div>
  </section>
</BaseLayout>
