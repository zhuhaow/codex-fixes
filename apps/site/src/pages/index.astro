---
import { readdirSync, readFileSync } from "node:fs";
import path from "node:path";
import BaseLayout from "../layouts/BaseLayout.astro";

type IssueStatus = "active" | "fixed" | "deprecated";
type IssueSeverity = "low" | "medium" | "high" | "critical";
type Applies = "Yes" | "No" | "Unknown";
type CodexSurface = "cli" | "desktop";
type TargetId =
  | "darwin-arm64"
  | "darwin-x64"
  | "linux-arm64"
  | "linux-x64"
  | "win32-arm64"
  | "win32-x64";

interface IssueTarget {
  applies: Applies;
  script?: string;
}

interface IssueManifest {
  $schema?: string;
  id: string;
  title: string;
  status: IssueStatus;
  severity: IssueSeverity;
  summary: string;
  sources: {
    issues: string[];
    fixes: string[];
  };
  targets: Partial<
    Record<CodexSurface, Partial<Record<TargetId, IssueTarget>>>
  >;
}

const severityRank: Record<IssueSeverity, number> = {
  critical: 0,
  high: 1,
  medium: 2,
  low: 3,
};

const severityStyles: Record<IssueSeverity, string> = {
  critical: "bg-rose-50 text-rose-700 ring-rose-200",
  high: "bg-amber-50 text-amber-700 ring-amber-200",
  medium: "bg-sky-50 text-sky-700 ring-sky-200",
  low: "bg-emerald-50 text-emerald-700 ring-emerald-200",
};

const surfaceLabels: Record<CodexSurface, string> = {
  cli: "CLI",
  desktop: "Desktop",
};

const targetLabels: Record<TargetId, string> = {
  "darwin-arm64": "macOS Apple silicon",
  "darwin-x64": "macOS Intel",
  "linux-arm64": "Linux ARM64",
  "linux-x64": "Linux x64",
  "win32-arm64": "Windows ARM64",
  "win32-x64": "Windows x64",
};

const sourceUrl = "https://github.com/zhuhaow/codex-fixes";

const links = [
  {
    label: "Report bug",
    href: "https://github.com/zhuhaow/codex-fixes/issues",
  },
  { label: "Install", href: "/install/" },
];

const issueStatuses = new Set<IssueStatus>(["active", "fixed", "deprecated"]);
const issueSeverities = new Set<IssueSeverity>([
  "low",
  "medium",
  "high",
  "critical",
]);

function assertIssueManifest(issue: unknown): asserts issue is IssueManifest {
  if (!issue || typeof issue !== "object") {
    throw new Error("Issue manifest must be an object.");
  }

  const manifest = issue as Partial<IssueManifest>;

  if (!manifest.id || typeof manifest.id !== "string") {
    throw new Error("Issue manifest is missing id.");
  }

  if (!manifest.status || !issueStatuses.has(manifest.status)) {
    throw new Error(`Issue ${manifest.id} has an invalid status.`);
  }

  if (!manifest.severity || !issueSeverities.has(manifest.severity)) {
    throw new Error(`Issue ${manifest.id} has an invalid severity.`);
  }

  if (!manifest.sources || !manifest.targets) {
    throw new Error(`Issue ${manifest.id} is missing sources or targets.`);
  }
}

function readIssueManifest(filePath: string): IssueManifest {
  const issue = JSON.parse(readFileSync(filePath, "utf8")) as unknown;
  assertIssueManifest(issue);

  return issue;
}

function loadIssues(): IssueManifest[] {
  const issuesDirectory = path.resolve(process.cwd(), "../../registry/issues");

  return readdirSync(issuesDirectory, { withFileTypes: true })
    .filter((entry) => entry.isDirectory())
    .map((entry) => path.join(issuesDirectory, entry.name, "issue.json"))
    .map(readIssueManifest)
    .sort((left, right) => left.id.localeCompare(right.id));
}

const issues = loadIssues();

const activeIssues = issues
  .filter((issue) => issue.status === "active")
  .sort(
    (left, right) =>
      severityRank[left.severity] - severityRank[right.severity] ||
      left.id.localeCompare(right.id),
  );

function titleCase(value: string): string {
  return value.charAt(0).toUpperCase() + value.slice(1);
}

function collectTargets(
  issue: IssueManifest,
  matches: (target: IssueTarget) => boolean,
): string[] {
  const labels: string[] = [];

  for (const [surface, targetMap] of Object.entries(issue.targets) as Array<
    [CodexSurface, Partial<Record<TargetId, IssueTarget>>]
  >) {
    for (const [targetId, target] of Object.entries(targetMap) as Array<
      [TargetId, IssueTarget]
    >) {
      if (matches(target)) {
        labels.push(`${surfaceLabels[surface]} · ${targetLabels[targetId]}`);
      }
    }
  }

  return labels;
}

function sourceLabel(url: string): string {
  const issueMatch = /\/issues\/(?<issueNumber>\d+)/.exec(url);
  const commentMatch = /#issuecomment-(?<commentId>\d+)/.exec(url);

  if (issueMatch?.groups?.issueNumber && commentMatch?.groups?.commentId) {
    return `#${issueMatch.groups.issueNumber} comment`;
  }

  if (issueMatch?.groups?.issueNumber) {
    return `#${issueMatch.groups.issueNumber}`;
  }

  return new URL(url).hostname;
}

const activeFixes = activeIssues.map((issue) => ({
  ...issue,
  knownAffected: collectTargets(issue, (target) => target.applies === "Yes"),
  fixAvailable: collectTargets(
    issue,
    (target) => target.applies === "Yes" && Boolean(target.script),
  ),
  needsVerification: collectTargets(
    issue,
    (target) => target.applies === "Unknown",
  ),
}));
---

<BaseLayout
  title="Codex Fixes"
  description="Community-maintained diagnostics and workarounds for Codex issues."
>
  <div
    class="min-h-screen bg-white text-gray-950 dark:bg-gray-950 dark:text-white"
  >
    <aside
      class="relative overflow-hidden bg-gray-950 px-6 text-white lg:fixed lg:inset-y-0 lg:left-0 lg:z-40 lg:flex lg:w-1/2 lg:items-center lg:px-0"
    >
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_80%_20%,rgba(56,189,248,0.28),rgba(3,7,18,0)_42%)]"
      >
      </div>
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_20%_85%,rgba(59,130,246,0.16),rgba(3,7,18,0)_36%)]"
      >
      </div>
      <div
        class="pointer-events-none absolute inset-0 [background-image:radial-gradient(circle_at_center,white_1px,transparent_1px)] [background-size:34px_34px] opacity-20"
      >
      </div>
      <div
        class="relative mx-auto flex w-full max-w-lg flex-col py-20 sm:py-32 lg:w-96 lg:py-0"
      >
        <div class="flex items-center justify-between gap-3">
          <a href="/" aria-label="codex-fixes home" class="inline-flex">
            <span class="text-2xl font-bold tracking-tight text-white"
              >codex-fixes</span
            >
          </a>
          <a
            href={sourceUrl}
            aria-label="View source on GitHub"
            title="View source on GitHub"
            class="rounded-md p-1.5 text-white/45 transition hover:bg-white/8 hover:text-sky-300"
          >
            <svg
              viewBox="0 0 24 24"
              aria-hidden="true"
              class="size-5 fill-current"
            >
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.39.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.61-4.04-1.61-.55-1.38-1.33-1.75-1.33-1.75-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.49.99.11-.77.42-1.3.76-1.6-2.66-.3-5.46-1.33-5.46-5.93 0-1.31.47-2.38 1.24-3.22-.12-.3-.54-1.52.12-3.18 0 0 1.01-.32 3.3 1.23A11.5 11.5 0 0 1 12 5.82c1.02 0 2.05.14 3.02.41 2.28-1.55 3.29-1.23 3.29-1.23.66 1.66.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.8 5.63-5.47 5.93.43.37.81 1.1.81 2.22v3.29c0 .32.22.69.82.58A12.01 12.01 0 0 0 24 12c0-6.63-5.37-12-12-12Z"
              ></path>
            </svg>
          </a>
        </div>

        <h1 class="mt-14 text-4xl/tight font-light text-white">
          Community-maintained fixes for <span class="text-sky-300"
            >Codex bugs</span
          >
        </h1>
        <p class="mt-4 text-sm/6 text-gray-300">
          When Codex bugs burn CPU, hammer your drive, or fill your disk, Codex
          Fixes gives you community workarounds now, while the official fix
          takes its sweet time.
        </p>

        <div
          class="mt-9 max-w-md rounded-lg bg-gradient-to-r from-sky-400/80 via-white/20 to-cyan-300/70 p-px shadow-[0_22px_80px_-32px_rgba(56,189,248,0.95)]"
        >
          <div class="rounded-lg bg-gray-950/95 p-4 ring-1 ring-white/10">
            <div class="flex items-center justify-between gap-4">
              <p class="text-xs/5 font-semibold tracking-[0.16em] text-sky-200 uppercase">
                Run the fixes
              </p>
            </div>
            <code class="mt-3 block font-mono text-lg/7 text-white">
              <span class="text-sky-300">$</span> npx codex-fixes
            </code>
          </div>
        </div>

        <div
          class="mt-8 flex flex-wrap justify-center gap-x-1 gap-y-3 sm:gap-x-2 lg:justify-start"
        >
          {
            links.map((link) => (
              <a
                href={link.href}
                class="group relative isolate flex items-center gap-x-3 rounded-lg px-2 py-0.5 text-[0.8125rem]/6 font-medium text-white/30 transition-colors hover:text-sky-300"
              >
                <span class="absolute inset-0 -z-10 scale-75 rounded-lg bg-white/5 opacity-0 transition group-hover:scale-100 group-hover:opacity-100" />
                <span class="self-baseline text-white">{link.label}</span>
              </a>
            ))
          }
        </div>
      </div>
    </aside>

    <section class="relative bg-white lg:ml-[50%]">
      <div class="mx-auto max-w-3xl px-6 py-16 sm:py-24 lg:px-10 xl:px-14">
        <div class="pb-8">
          <h2
            class="text-xs/5 font-semibold tracking-[0.16em] text-sky-600 uppercase"
          >
            Current bugs and fixes
          </h2>
        </div>

        <div class="mt-2">
          {
            activeFixes.map((issue) => (
              <article id={issue.id} class="border-t border-gray-950/10 py-8">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="rounded-md bg-gray-100 px-2 py-1 font-mono text-xs text-gray-600">
                    {issue.id}
                  </span>
                  <span
                    class={`rounded-full px-2.5 py-1 text-xs font-semibold ring-1 ${severityStyles[issue.severity]}`}
                  >
                    {titleCase(issue.severity)}
                  </span>
                </div>

                <h3 class="mt-4 text-xl/7 font-semibold tracking-tight text-gray-950">
                  <a href={`#${issue.id}`}>{issue.title}</a>
                </h3>
                <p class="mt-3 text-sm/6 text-gray-600">{issue.summary}</p>

                <div class="mt-6 grid gap-4">
                  <div>
                    <h4 class="text-xs/5 font-semibold text-gray-950">
                      Known affected
                    </h4>
                    <div class="mt-2 flex flex-wrap gap-2">
                      {issue.knownAffected.length > 0 ? (
                        issue.knownAffected.map((label) => (
                          <span class="rounded-full bg-rose-50 px-2.5 py-1 text-xs font-medium text-rose-700 ring-1 ring-rose-100">
                            {label}
                          </span>
                        ))
                      ) : (
                        <span class="text-sm/6 text-gray-500">
                          Still being confirmed.
                        </span>
                      )}
                    </div>
                  </div>

                  <div>
                    <h4 class="text-xs/5 font-semibold text-gray-950">
                      Fix available for
                    </h4>
                    <div class="mt-2 flex flex-wrap gap-2">
                      {issue.fixAvailable.map((label) => (
                        <span class="rounded-full bg-emerald-50 px-2.5 py-1 text-xs font-medium text-emerald-700 ring-1 ring-emerald-100">
                          {label}
                        </span>
                      ))}
                    </div>
                  </div>

                  {issue.needsVerification.length > 0 && (
                    <div>
                      <h4 class="text-xs/5 font-semibold text-gray-950">
                        Needs verification
                      </h4>
                      <div class="mt-2 flex flex-wrap gap-2">
                        {issue.needsVerification.map((label) => (
                          <span class="rounded-full bg-gray-50 px-2.5 py-1 text-xs font-medium text-gray-600 ring-1 ring-gray-200">
                            {label}
                          </span>
                        ))}
                      </div>
                    </div>
                  )}
                </div>

                <div class="mt-6">
                  <h4 class="text-xs/5 font-semibold text-gray-950">Sources</h4>
                  <div class="mt-2 flex flex-wrap gap-2">
                    {issue.sources.issues.map((source) => (
                      <a
                        href={source}
                        class="rounded-md bg-gray-50 px-2.5 py-1 text-xs font-medium text-gray-700 ring-1 ring-gray-200 transition hover:bg-sky-50 hover:text-sky-700 hover:ring-sky-200"
                      >
                        Issue {sourceLabel(source)}
                      </a>
                    ))}
                    {issue.sources.fixes.map((source) => (
                      <a
                        href={source}
                        class="rounded-md bg-sky-50 px-2.5 py-1 text-xs font-medium text-sky-700 ring-1 ring-sky-200 transition hover:bg-sky-100"
                      >
                        Fix source {sourceLabel(source)}
                      </a>
                    ))}
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
