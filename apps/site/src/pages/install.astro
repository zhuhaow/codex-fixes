---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Install - Codex Fixes"
  description="Install and run the Codex Fixes CLI."
>
  <div class="min-h-screen bg-white px-6 py-16 text-gray-950 sm:px-8 sm:py-24">
    <div class="mx-auto max-w-3xl">
      <a href="/" class="text-sm font-semibold text-sky-300">Codex Fixes</a>
      <p
        class="mt-12 text-xs/6 font-semibold tracking-[0.18em] text-sky-300 uppercase"
      >
        CLI
      </p>
      <h1
        class="mt-3 text-4xl/tight font-light text-gray-950 sm:text-5xl/tight"
      >
        Start with a local diagnosis.
      </h1>
      <p class="mt-5 max-w-2xl text-base/7 text-gray-600">
        The initial CLI scaffold only prints command placeholders. Future fixes
        should default to read-only diagnostics before changing local Codex
        state.
      </p>
      <div class="mt-8 rounded-xl border border-gray-950/10 bg-gray-50 p-2">
        <pre
          class="overflow-x-auto rounded-lg bg-gray-950 px-4 py-3 text-sm/6 text-gray-100"><code>npx codex-fixes doctor</code></pre>
      </div>
    </div>
  </div>
</BaseLayout>
