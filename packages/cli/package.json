{
  "name": "codex-fixes",
  "version": "0.1.3",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhuhaow/codex-fixes.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/zhuhaow/codex-fixes/issues"
  },
  "homepage": "https://codexfixes.com",
  "bin": {
    "codex-fixes": "dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "tsc -p tsconfig.json && node dist/index.js",
    "build": "tsc -p tsconfig.json && node scripts/copy-registry.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.6.0",
    "commander": "^11.1.0",
    "picocolors": "^1.1.1",
    "zod": "^3.25.76"
  }
}
