{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "codex-fixes",
  "compatibility_date": "2026-06-21",
  "workers_dev": true,
  "routes": [
    {
      "pattern": "codexfixes.com",
      "custom_domain": true,
    },
    {
      "pattern": "www.codexfixes.com",
      "custom_domain": true,
    },
  ],
  "assets": {
    "directory": "./apps/site/dist",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page",
  },
}
