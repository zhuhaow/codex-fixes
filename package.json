{
  "name": "codex-fixes",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=22 <25",
    "npm": ">=10"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @codex-fixes/site",
    "build": "npm run build --workspaces --if-present",
    "build:site": "npm run build -w @codex-fixes/site",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "cli": "npm run dev -w @codex-fixes/cli --"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.103.0"
  }
}
