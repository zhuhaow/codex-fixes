{
  "name": "codex-fixes-monorepo",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=22 <25",
    "npm": ">=10"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @codex-fixes/site",
    "build": "npm run build --workspaces --if-present",
    "build:site": "npm run build -w @codex-fixes/site",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "tsc -p registry/tsconfig.json --noEmit && npm run typecheck --workspaces --if-present",
    "cli": "npm run dev -w codex-fixes --"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.103.0"
  }
}
